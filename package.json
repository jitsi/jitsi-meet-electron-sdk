{
  "name": "@jitsi/electron-sdk",
  "version": "9.1.3",
  "description": "Utilities for jitsi-meet-electron project",
  "main": "index.js",
  "exports": {
    ".": "./index.js",
    "./remotecontrol/main": "./remotecontrol/main.js",
    "./remotecontrol/render": "./remotecontrol/render.js",
    "./screensharing/main": "./screensharing/main.js",
    "./screensharing/render": "./screensharing/render.js",
    "./screensharing/preload": "./screensharing/preload.js",
    "./pip/main": "./pip/main.js",
    "./pip/render": "./pip/render.js",
    "./powermonitor/main": "./powermonitor/main.js",
    "./powermonitor/render": "./powermonitor/render.js",
    "./popupsconfig/main": "./popupsconfig/main.js",
    "./popupsconfig/render": "./popupsconfig/render.js",
    "./*": "./*"
  },
  "scripts": {
    "lint": "eslint .",
    "test": "mocha",
    "validate": "npm ls",
    "install": "node install.js",
    "node-gyp-build": "node-gyp-build",
    "prebuild": "prebuildify -t 20.0.0 --strip"
  },
  "pre-commit": [
    "lint"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jitsi/jitsi-meet-electron-sdk.git"
  },
  "keywords": [
    "jingle",
    "webrtc",
    "xmpp",
    "electron",
    "jitsi-meet",
    "utils"
  ],
  "author": "",
  "readmeFilename": "README.md",
  "license": "Apache-2.0",
  "gypfile": true,
  "binary": {
    "napi_versions": [
      3
    ]
  },
  "dependencies": {
    "@jitsi/logger": "^2.0.2",
    "@jitsi/robotjs": "^0.6.15",
    "node-addon-api": "^8.0.0",
    "node-gyp-build": "4.8.4",
    "postis": "^2.2.0"
  },
  "devDependencies": {
    "eslint": ">=3",
    "eslint-plugin-jsdoc": "*",
    "husky": "^9.0.10",
    "mocha": "^11.7.3",
    "prebuildify": "^6.0.0",
    "precommit-hook": "3.0.0"
  }
}
